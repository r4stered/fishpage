.github/
.venv/
.vscode/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
dist/
build/
*.egg-info/
tests/
docs/
*.db
*.sqlite*
.DS_Store
