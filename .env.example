# Bootstrap secrets for `just bootstrap`. Copy to `.env` (gitignored) and fill in. `just` auto-loads
# it, so you never `export` these by hand. Non-secret values (account/zone IDs, hostname) do NOT go
# here — those live in infra/terraform.tfvars. Nothing here is committed.

# --- Cloudflare ---
# My Profile -> API Tokens -> Create Token. Needs: Account > Workers R2 Storage (Edit),
# Account > Cloudflare Tunnel (Edit), Account > Access: Apps and Policies (Edit),
# Zone > DNS (Edit) for your domain. A ~40-char string, no prefix.
CLOUDFLARE_API_TOKEN=

# --- GitHub ---
# A PAT with repo scope (fine-grained: Secrets read/write on r4stered/fishpage). Starts with ghp_.
GITHUB_TOKEN=

# --- Grafana Cloud ---
# grafana.com -> Account -> Access Policies: a token with accesspolicies:read|write + stacks:read.
# Starts with glc_.
GRAFANA_CLOUD_ACCESS_POLICY_TOKEN=
# Your <stack>.grafana.net -> Administration -> Service accounts -> add a token (Admin role).
# Starts with glsa_.
GRAFANA_AUTH=

# --- R2 remote-state bucket (S3 API keys) ---
# Cloudflare dashboard -> R2 -> Manage R2 API Tokens -> Create. The result gives an Access Key ID
# (~32 hex) and a Secret Access Key (~64 hex). These authenticate the encrypted state backend.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Fly ---
# Paste the output of: fly tokens create deploy -a fishpage   (starts with "FlyV1 ").
# Set as the FLY_API_TOKEN GitHub Actions secret AND used below to authenticate flyctl.
TF_VAR_fly_deploy_token=
# Authenticate the flyctl CLI itself. Set to the same deploy token above, or remove this line and
# run `fly auth login` instead.
FLY_API_TOKEN=

# --- OpenTofu state encryption ---
# A passphrase you choose, >= 16 chars. It derives the key that encrypts remote state (which holds
# the minted secrets). Guard it like the secrets themselves — losing it locks you out of state.
TF_VAR_state_encryption_passphrase=
